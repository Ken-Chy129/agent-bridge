{
  "name": "@ken-chy129/agent-bridge",
  "version": "0.1.1",
  "description": "Bridge local coding agents (Claude Code, Codex, …) to Feishu/Lark with daemon-hosted multi-view sessions",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ken-Chy129/agent-bridge.git"
  },
  "homepage": "https://github.com/Ken-Chy129/agent-bridge#readme",
  "bugs": {
    "url": "https://github.com/Ken-Chy129/agent-bridge/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "agent-bridge": "bin/agent-bridge.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "pnpm typecheck && pnpm build"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.152",
    "@larksuiteoapi/node-sdk": "^1.64.0",
    "commander": "^12.1.0",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/qrcode-terminal": "^0.12.2",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "feishu",
    "lark",
    "claude",
    "codex",
    "agent",
    "bridge",
    "daemon"
  ],
  "license": "MIT"
}
